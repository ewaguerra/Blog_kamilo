---
interface CourseInfo {
  turma: string;
  valor: number;
  valorOriginal?: number;
  vagas?: number;
  formato: string;
  cargaHoraria: string;
  inicio: string;
  parcelas?: string;
}

interface Props {
  info: CourseInfo;
}

const { info } = Astro.props;

const price = new Intl.NumberFormat('pt-BR', {
  style: 'currency',
  currency: 'BRL',
  maximumFractionDigits: 0,
}).format(info.valor);

const originalPrice =
  info.valorOriginal !== undefined
    ? new Intl.NumberFormat('pt-BR', {
        style: 'currency',
        currency: 'BRL',
        maximumFractionDigits: 0,
      }).format(info.valorOriginal)
    : undefined;

const details = [
  { label: 'Turma', value: info.turma },
  { label: 'Formato', value: info.formato },
  { label: 'Carga horária', value: info.cargaHoraria },
  { label: 'Início', value: info.inicio },
  ...(info.vagas !== undefined ? [{ label: 'Vagas', value: `${info.vagas} vagas` }] : []),
];
---

<div
  class="mx-auto mt-6 max-w-md rounded-[1.25rem] border p-5 text-left sm:max-w-lg sm:p-6"
  style="border-color: var(--border); background: var(--bg-elevated);"
>
  <div class="mb-5 text-center">
    <p class="text-xs font-medium uppercase tracking-wider" style="color: var(--text-muted);">
      Investimento
    </p>
    <div class="mt-2 flex flex-wrap items-baseline justify-center gap-2">
      <span class="text-3xl font-bold tracking-tight" style="color: var(--text);">{price}</span>
      {
        originalPrice && (
          <span class="text-sm line-through" style="color: var(--text-muted);">
            {originalPrice}
          </span>
        )
      }
    </div>
    {
      info.parcelas && (
        <p class="mt-1 text-sm" style="color: var(--text-muted);">
          {info.parcelas}
        </p>
      )
    }
  </div>

  <dl class="grid gap-3 border-t pt-5 text-sm" style="border-color: var(--border);">
    {
      details.map(({ label, value }) => (
        <div class="flex items-start justify-between gap-4">
          <dt style="color: var(--text-muted);">{label}</dt>
          <dd class="text-right font-medium" style="color: var(--text);">{value}</dd>
        </div>
      ))
    }
  </dl>
</div>
