---
import { SITE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/', label: 'Início' },
  { href: '/blog', label: 'Blog' },
  { href: '/sobre', label: 'Sobre' },
];

const currentPath = Astro.url.pathname;
---

<header class="sticky top-0 z-50 border-b backdrop-blur-md" style="border-color: var(--border); background: color-mix(in srgb, var(--bg) 85%, transparent);">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
    <a href="/" class="group flex items-center gap-2">
      <span
        class="flex h-8 w-8 items-center justify-center rounded-lg text-sm font-bold text-white"
        style="background: linear-gradient(135deg, var(--accent) 0%, var(--color-accent-cyan) 100%);"
      >
        K
      </span>
      <span class="text-lg font-semibold tracking-tight">{SITE.title}</span>
    </a>

    <nav class="flex items-center gap-1 sm:gap-2">
      {
        navItems.map(({ href, label }) => {
          const isActive =
            href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(href);

          return (
            <a
              href={href}
              class:list={[
                'rounded-lg px-3 py-2 text-sm font-medium transition-colors',
                isActive ? 'text-[var(--text)]' : 'text-[var(--text-muted)] hover:text-[var(--text)]',
              ]}
              style={isActive ? 'background: var(--bg-muted);' : undefined}
            >
              {label}
            </a>
          );
        })
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
