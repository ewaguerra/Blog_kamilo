---
import { SITE } from '../consts';
import ThemeToggle from './ThemeToggle.astro';

const navItems = [
  { href: '/', label: 'Início' },
  { href: '/blog', label: 'Blog' },
  { href: '/sobre', label: 'Sobre' },
];

const currentPath = Astro.url.pathname;
---

<header class="border-b" style="border-color: var(--border); background: var(--bg);">
  <div class="mx-auto flex max-w-6xl items-center justify-between px-4 py-5 sm:px-6">
    <a href="/" class="flex items-center gap-2.5">
      <span
        class="flex h-8 w-8 items-center justify-center rounded-full text-sm font-bold"
        style="background: var(--text); color: var(--bg-elevated);"
      >
        K
      </span>
      <span class="text-base font-semibold tracking-tight">{SITE.title}</span>
    </a>

    <nav class="flex items-center gap-1 sm:gap-2">
      {
        navItems.map(({ href, label }) => {
          const isActive =
            href === '/'
              ? currentPath === '/'
              : currentPath.startsWith(href);

          return (
            <a
              href={href}
              class:list={[
                'rounded-full px-3.5 py-2 text-sm font-medium transition-colors',
                isActive
                  ? 'bg-[var(--bg-muted)] text-[var(--text)]'
                  : 'text-[var(--text-muted)] hover:text-[var(--text)]',
              ]}
            >
              {label}
            </a>
          );
        })
      }
      <ThemeToggle />
    </nav>
  </div>
</header>
