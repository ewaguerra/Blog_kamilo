---
import { SITE } from '../consts';

function youtubeVideoId(url: string): string {
  const fromWatch = url.split('v=')[1]?.split('&')[0];
  const fromEmbed = url.split('/embed/')[1]?.split('?')[0];
  return fromWatch ?? fromEmbed ?? url;
}

const featuredVideos = SITE.social.youtubeFeatured.map((url, index) => ({
  id: youtubeVideoId(url),
  title: `Vídeo em destaque ${index + 1} — Mago Domine Callidus`,
}));
---

<section class="pb-8 pt-4 sm:pb-12">
  <div
    class="overflow-hidden rounded-[var(--radius-2xl)] border p-6 sm:p-8 lg:p-10"
    style="border-color: var(--border); background: var(--bg-elevated);"
  >
    <div class="mb-8 flex flex-col gap-6 sm:flex-row sm:items-center sm:justify-between">
      <div class="max-w-xl">
        <span class="pill mb-4">YouTube</span>
        <h2 class="mb-3 text-2xl font-bold tracking-tight sm:text-3xl">
          Mago Domine Callidus
        </h2>
        <p class="text-sm leading-relaxed sm:text-base" style="color: var(--text-muted);">
          Aulas, estudos e mentoria em vídeo — complemento formativo aos textos publicados aqui.
        </p>
      </div>

      <a
        href={SITE.social.youtube}
        target="_blank"
        rel="noopener noreferrer"
        class="btn-primary inline-flex shrink-0 items-center justify-center gap-2.5 min-w-[200px]"
      >
        <svg class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path
            d="M23.498 6.186a3.016 3.016 0 0 0-2.122-2.136C19.505 3.545 12 3.545 12 3.545s-7.505 0-9.377.505A3.017 3.017 0 0 0 .502 6.186C0 8.07 0 12 0 12s0 3.93.502 5.814a3.016 3.016 0 0 0 2.122 2.136c1.871.505 9.376.505 9.376.505s7.505 0 9.377-.505a3.015 3.015 0 0 0 2.122-2.136C24 15.93 24 12 24 12s0-3.93-.502-5.814zM9.545 15.568V8.432L15.818 12l-6.273 3.568z"
          ></path>
        </svg>
        Ver canal
      </a>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 sm:gap-5">
      {
        featuredVideos.map((video) => (
          <div
            class="overflow-hidden rounded-[1.25rem] border"
            style="border-color: var(--border);"
          >
            <div class="relative aspect-video w-full">
              <iframe
                src={`https://www.youtube-nocookie.com/embed/${video.id}`}
                title={video.title}
                class="absolute inset-0 h-full w-full"
                allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
                allowfullscreen
                loading="lazy"
                referrerpolicy="strict-origin-when-cross-origin"></iframe>
            </div>
          </div>
        ))
      }
    </div>
  </div>
</section>
