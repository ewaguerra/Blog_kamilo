---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada" description="A página que você procura não existe.">
  <section class="py-20 text-center">
    <p class="mb-2 text-7xl font-bold tracking-tight">404</p>
    <h1 class="mb-4 text-2xl font-bold">Página não encontrada</h1>
    <p class="mb-8" style="color: var(--text-muted);">
      O conteúdo que você procura não existe ou foi movido.
    </p>
    <a href="/" class="btn-primary">Voltar ao início</a>
  </section>
</BaseLayout>
