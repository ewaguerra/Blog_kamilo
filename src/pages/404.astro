---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Página não encontrada" description="A página que você procura não existe.">
  <section class="py-20 text-center">
    <p class="mb-2 text-6xl font-bold gradient-text">404</p>
    <h1 class="mb-4 text-2xl font-bold">Página não encontrada</h1>
    <p class="mb-8" style="color: var(--text-muted);">
      O conteúdo que você procura não existe ou foi movido.
    </p>
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-xl px-6 py-3 text-sm font-medium text-white transition-opacity hover:opacity-90"
      style="background: linear-gradient(135deg, var(--accent) 0%, var(--color-accent-cyan) 100%);"
    >
      Voltar ao início
    </a>
  </section>
</BaseLayout>
