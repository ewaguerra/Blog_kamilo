---
import BaseLayout from '../layouts/BaseLayout.astro';
import Footer from '../components/Footer.astro';
import ThemeToggle from '../components/ThemeToggle.astro';
import PostCard from '../components/PostCard.astro';
import CoursePromo from '../components/CoursePromo.astro';
import YouTubeSection from '../components/YouTubeSection.astro';
import { SITE } from '../consts';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

const recent = posts.slice(0, 3);

const trustItems = [
  { label: 'Estudos', icon: 'M12 6.253v13m0-13C10.832 5.477 9.246 5 7.5 5S4.168 5.477 3 6.253v13C4.168 18.477 5.754 18 7.5 18s3.332.477 4.5 1.253m0-13C13.168 5.477 14.754 5 16.5 5c1.747 0 3.332.477 4.5 1.253v13C19.832 18.477 18.247 18 16.5 18c-1.746 0-3.332.477-4.5 1.253' },
  { label: 'Traduções', icon: 'M3 5h12M9 3v2m1.048 9.5A18.022 18.022 0 016.412 9m6.088 9h5M11 21l5-10 5 10M12.751 5C11.783 10.77 8.07 15.61 3 18.129' },
  { label: 'Práticas', icon: 'M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z' },
  { label: 'Mentoria', icon: 'M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z' },
];

const heroImages = [
  { src: '/images/hero-hecate.png', alt: 'Hécate e a lua tripla — deuses ctônicos' },
  { src: '/images/hero-serapis.png', alt: 'Serápis e Alexandria' },
  { src: '/images/hero-pgm-papyrus.png', alt: 'Papiro mágico grego com Anúbis e Thoth' },
  { src: '/images/hero-ouroboros.png', alt: 'Círculo ouroborico e heptagrama' },
  { src: '/images/hero-lecanomancia.png', alt: 'Lecanomancia — tigela de água sob a lua' },
  { src: '/images/hero-papyrus-stars.png', alt: 'Papiro sob o céu estrelado' },
  { src: '/images/hero-iao.png', alt: 'Sigilo IAO em pedra antiga' },
];

const features = [
  {
    title: 'Papiros Mágicos Gregos',
    description: 'Textos helenísticos onde deuses ctônicos, voces magicae e astrologia formam uma religião operativa unificada.',
    visual: 'pgm',
  },
  {
    title: 'Hygromanteia',
    description: 'Visões pela água, lecanomancia e tigelas de óleo — da divinação grega ao scrying moderno.',
    visual: 'water',
  },
  {
    title: 'Goetia e nigromancia',
    description: 'A linha curta do goes helenístico até Mathers: Akhephalos, círculo ouroborico e grimórios bizantinos.',
    visual: 'circle',
  },
  {
    title: 'Sincretismo helenístico',
    description: 'Serápis, Hécate, Iao e Osíris — quando o submundo torna-se o eixo da magia prática terrena.',
    visual: 'sync',
  },
];
---

<BaseLayout wide bare>
  <div class="mx-auto max-w-6xl px-4 sm:px-6">
    <!-- Hero -->
    <section
      class="relative overflow-hidden rounded-[var(--radius-3xl)] px-6 pb-0 pt-6 sm:px-10 sm:pt-8"
      style="background: var(--bg-muted);"
    >
      <div class="mb-10 flex items-center justify-between">
        <a href="/" class="flex items-center gap-2.5">
          <span
            class="flex h-8 w-8 items-center justify-center rounded-full text-sm font-bold"
            style="background: var(--text); color: var(--bg-elevated);"
          >
            M
          </span>
          <span class="text-base font-semibold">{SITE.title}</span>
        </a>
        <div class="flex items-center gap-2">
          <a href="/#cursos" class="hidden rounded-full px-3.5 py-2 text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--text)] sm:inline-block">
            Curso
          </a>
          <a href="/blog" class="hidden rounded-full px-3.5 py-2 text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--text)] sm:inline-block">
            Blog
          </a>
          <a href="/sobre" class="hidden rounded-full px-3.5 py-2 text-sm font-medium text-[var(--text-muted)] transition-colors hover:text-[var(--text)] sm:inline-block">
            Sobre
          </a>
          <ThemeToggle />
        </div>
      </div>

      <div class="mx-auto mb-8 flex justify-center">
        <span class="pill">
          <span class="inline-block h-1.5 w-1.5 rounded-full" style="background: var(--text);"></span>
          {SITE.tagline}
        </span>
      </div>

      <div class="mx-auto max-w-3xl text-center">
        <h1 class="mb-5 text-4xl font-bold leading-[1.08] tracking-tight sm:text-5xl lg:text-[3.25rem]">
          Estudos. Traduções. Práticas.<br />
          Mentoria em ocultismo.
        </h1>
        <p class="mx-auto mb-8 max-w-xl text-base leading-relaxed sm:text-lg" style="color: var(--text-muted);">
          {SITE.description}
        </p>

        <div class="mb-8 flex justify-center">
          <div
            class="inline-flex items-center gap-3 rounded-full border px-4 py-2.5 shadow-sm"
            style="border-color: var(--border); background: var(--bg-elevated);"
          >
            <span class="flex gap-1">
              <span class="h-2 w-2 rounded-full" style="background: #ef4444;"></span>
              <span class="h-2 w-2 rounded-full" style="background: #eab308;"></span>
              <span class="h-2 w-2 rounded-full" style="background: #22c55e;"></span>
            </span>
            <span class="text-xs font-medium" style="color: var(--text-muted);">PGM · hygromanteia · goetia</span>
          </div>
        </div>

        <div class="mb-12 flex flex-col items-center justify-center gap-3 sm:flex-row">
          <a href="/blog" class="btn-primary min-w-[180px]">Explorar estudos</a>
          <a href="/#cursos" class="btn-secondary min-w-[180px]">Ver cursos</a>
        </div>
      </div>

      <div class="hero-carousel relative mx-auto max-w-4xl overflow-hidden rounded-t-[2rem]">
        {
          heroImages.map((img, i) => (
            <img
              src={img.src}
              alt={img.alt}
              class="hero-slide"
              style={`animation-delay: ${-i * 6}s`}
              loading={i === 0 ? 'eager' : 'lazy'}
              decoding="async"
            />
          ))
        }
      </div>
    </section>

    <!-- Trust bar -->
    <section class="flex flex-wrap items-center justify-center gap-6 py-8 sm:gap-10">
      {
        trustItems.map(({ label, icon }) => (
          <div class="flex items-center gap-2 text-sm" style="color: var(--text-muted);">
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="1.5">
              <path stroke-linecap="round" stroke-linejoin="round" d={icon} />
            </svg>
            {label}
          </div>
        ))
      }
    </section>

    <CoursePromo />

    <!-- Feature grid -->
    <section class="py-10 sm:py-16">
      <div class="mx-auto mb-12 max-w-2xl text-center">
        <h2 class="text-3xl font-bold tracking-tight sm:text-4xl">
          Do helenismo ao grimório.<br class="hidden sm:block" />
          Uma tradição contínua.
        </h2>
      </div>

      <div class="grid gap-5 sm:grid-cols-2">
        {
          features.map(({ title, description, visual }) => (
            <article
              class="surface-card flex flex-col overflow-hidden rounded-[var(--radius-2xl)] p-6 sm:p-8"
            >
              <div
                class="mb-6 flex min-h-[140px] items-center justify-center rounded-[1.25rem] p-4"
                style="background: var(--bg-elevated);"
              >
                {visual === 'pgm' && (
                  <div class="w-full max-w-[220px] space-y-2 text-center">
                    <div class="rounded-lg px-3 py-2 text-xs font-medium tracking-widest" style="background: var(--text); color: var(--bg-elevated);">
                      PGM V · 96–172
                    </div>
                    <div class="rounded-lg border px-3 py-2 text-xs italic" style="border-color: var(--border); color: var(--text-muted);">
                      Akhephalos<br />Cabeça-sem-Cabeça
                    </div>
                  </div>
                )}
                {visual === 'water' && (
                  <div class="relative flex h-20 w-20 items-center justify-center rounded-full border-2" style="border-color: var(--border);">
                    <div class="absolute inset-2 rounded-full" style="background: linear-gradient(180deg, var(--bg-muted) 0%, var(--text-muted) 100%); opacity: 0.4;"></div>
                    <span class="relative text-[10px] font-medium uppercase tracking-wider">H₂O</span>
                  </div>
                )}
                {visual === 'circle' && (
                  <svg viewBox="0 0 100 100" class="h-24 w-24" fill="none" stroke="currentColor" stroke-width="1.5" style="color: var(--text);">
                    <circle cx="50" cy="50" r="35" />
                    <path d="M15 50 Q50 15 85 50 Q50 85 15 50" stroke-dasharray="4 2" />
                    <circle cx="50" cy="50" r="8" fill="currentColor" />
                  </svg>
                )}
                {visual === 'sync' && (
                  <div class="flex flex-wrap justify-center gap-2 text-[10px] font-medium uppercase tracking-wide">
                    {['Hécate', 'Iao', 'Osíris', 'Serápis'].map((name) => (
                      <span class="pill py-1">{name}</span>
                    ))}
                  </div>
                )}
                {visual === 'markdown' && (
                  <div class="w-full max-w-[220px] space-y-2">
                    <div class="rounded-lg px-3 py-2 text-xs font-medium" style="background: var(--text); color: var(--bg-elevated);">
                      Novo post.md
                    </div>
                    <div class="rounded-lg border px-3 py-2 text-xs" style="border-color: var(--border); color: var(--text-muted);">
                      ---<br />title: Artigo<br />---
                    </div>
                  </div>
                )}
                {visual === 'stats' && (
                  <div class="w-full max-w-[240px] space-y-2">
                    {['Posts publicados', 'Tags usadas', 'Tempo de build'].map((label, i) => (
                      <div class="flex items-center justify-between rounded-lg border px-3 py-2 text-xs" style="border-color: var(--border);">
                        <span style="color: var(--text-muted);">{label}</span>
                        <span class="font-semibold">{['3', '8', '<1s'][i]}</span>
                      </div>
                    ))}
                  </div>
                )}
                {visual === 'mountain' && (
                  <svg viewBox="0 0 200 80" class="h-20 w-full max-w-[200px]" fill="currentColor" style="color: var(--text);">
                    <path d="M0 80 L60 30 L100 55 L140 15 L200 80 Z" opacity="0.9" />
                    <path d="M0 80 L80 45 L120 60 L160 35 L200 80 Z" opacity="0.4" />
                  </svg>
                )}
                {visual === 'web' && (
                  <div class="relative flex h-24 w-24 items-center justify-center">
                    <div class="absolute inset-0 rounded-full border-2" style="border-color: var(--border);"></div>
                    <div class="absolute inset-3 rounded-full border" style="border-color: var(--text-muted); opacity: 0.3;"></div>
                    <span class="rounded-full px-2 py-0.5 text-[10px] font-medium" style="background: var(--text); color: var(--bg-elevated);">
                      &lt; 1s
                    </span>
                  </div>
                )}
              </div>
              <h3 class="mb-2 text-lg font-semibold tracking-tight">{title}</h3>
              <p class="text-sm leading-relaxed" style="color: var(--text-muted);">{description}</p>
            </article>
          ))
        }
      </div>
    </section>

    <!-- Recent posts -->
    {
      recent.length > 0 && (
        <section class="pb-8 pt-4 sm:pb-12">
          <div class="mb-8 flex items-end justify-between">
            <div>
              <h2 class="text-2xl font-bold tracking-tight">Estudos recentes</h2>
              <p class="mt-1 text-sm" style="color: var(--text-muted);">
                Artigos, traduções e análises publicados
              </p>
            </div>
            <a href="/blog" class="hidden text-sm font-medium transition-opacity hover:opacity-60 sm:inline-block">
              Ver todos →
            </a>
          </div>
          <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
            {recent.map((post) => (
              <PostCard post={post} compact />
            ))}
          </div>
        </section>
      )
    }

    <YouTubeSection />
  </div>

  <Footer />
</BaseLayout>
