---
import { type CollectionEntry, getCollection, render } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ArticleAuthor from '../../components/ArticleAuthor.astro';
import ArticleAuthorBio from '../../components/ArticleAuthorBio.astro';
import CourseCta from '../../components/CourseCta.astro';
import CourseLayout from '../../components/CourseLayout.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import RecommendedPosts from '../../components/RecommendedPosts.astro';
import TableOfContents from '../../components/TableOfContents.astro';
import { getRecommendedPosts } from '../../lib/recommendations';
import { getTocHeadings } from '../../lib/toc';

export async function getStaticPaths() {
  const posts = await getCollection('blog', ({ data }) => !data.draft);
  return posts.map((post) => ({
    params: { slug: post.id },
    props: post,
  }));
}

type Props = CollectionEntry<'blog'>;

const post = Astro.props;
const { Content, headings } = await render(post);
const allPosts = await getCollection('blog', ({ data }) => !data.draft);
const {
  title,
  description,
  pubDate,
  updatedDate,
  tags,
  image,
  author,
  authorBio,
  kind,
  courseUrl,
  highlights,
  modules,
  relatedCourseSlug,
  courseInfo,
} = post.data;
const isCourse = kind === 'curso';
const tocHeadings = !isCourse ? getTocHeadings(headings) : [];
const showToc = tocHeadings.length > 0;
const recommendedPosts = !isCourse ? getRecommendedPosts(allPosts, post) : [];
---

<BaseLayout title={title} description={description} image={image} wide={showToc}>
  <div class:list={['article-layout', showToc && 'article-layout--with-toc']}>
    {showToc && <TableOfContents headings={tocHeadings} />}
    <article class:list={[isCourse ? 'course-page max-w-3xl' : 'article-page', 'mx-auto']}>
    {
      isCourse ? (
        <>
          <header
            class="article-header mb-10 border-b pb-10 text-center"
            style="border-color: var(--border);"
          >
            <div
              class="mb-4 flex flex-wrap items-center justify-center gap-3 text-sm"
              style="color: var(--text-muted);"
            >
              <span class="pill py-0.5 text-xs">Curso</span>
              <FormattedDate date={pubDate} />
              {
                updatedDate && (
                  <span>
                    · Atualizado em{' '}
                    {updatedDate.toLocaleDateString('pt-BR', {
                      day: 'numeric',
                      month: 'long',
                      year: 'numeric',
                    })}
                  </span>
                )
              }
            </div>

            <h1 class="mb-4 text-3xl font-bold tracking-tight sm:text-4xl lg:text-5xl">
              {title}
            </h1>

            {
              tags.length > 0 && (
                <div class="mt-5 flex flex-wrap justify-center gap-2">
                  {tags.map((tag) => (
                    <span class="pill text-xs">{tag}</span>
                  ))}
                </div>
              )
            }
          </header>

          {
            courseUrl && (
              <CourseLayout
                title={title}
                description={description}
                url={courseUrl}
                image={image}
                highlights={highlights}
                modules={modules}
                relatedCourseSlug={relatedCourseSlug}
                courseInfo={courseInfo}
              />
            )
          }

          <div class="prose mx-auto">
            <Content />
            {
              courseUrl && (
                <CourseCta
                  url={courseUrl}
                  title="Inscrever-se no YouTube"
                  headline="Comece a ler o seu céu hoje"
                />
              )
            }
          </div>
        </>
      ) : (
        <>
          <header class="article-header">
            <div class="article-meta">
              <span class="pill py-0.5 text-xs">Estudo</span>
              <FormattedDate date={pubDate} />
              {
                updatedDate && (
                  <span>
                    · Atualizado em{' '}
                    {updatedDate.toLocaleDateString('pt-BR', {
                      day: 'numeric',
                      month: 'long',
                      year: 'numeric',
                    })}
                  </span>
                )
              }
            </div>

            <h1 class="article-title">{title}</h1>

            <p class="article-deck">{description}</p>

            <ArticleAuthor author={author} />

            {
              tags.length > 0 && (
                <div class="article-tags">
                  {tags.map((tag) => (
                    <span class="pill text-xs">{tag}</span>
                  ))}
                </div>
              )
            }
          </header>

          {
            image && (
              <figure class="article-cover">
                <img
                  src={image}
                  alt={title}
                  class="aspect-[5/3] w-full object-cover sm:aspect-[2/1]"
                  loading="eager"
                  decoding="async"
                />
              </figure>
            )
          }

          <div class="article-body prose">
            <Content />
          </div>

          <ArticleAuthorBio author={author} bio={authorBio} />

          <RecommendedPosts posts={recommendedPosts} />
        </>
      )
    }

    <footer class:list={['article-footer', isCourse && 'text-center']}>
      <a
        href="/blog"
        class="inline-flex items-center gap-2 text-sm font-medium transition-opacity hover:opacity-60"
      >
        <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Voltar aos estudos
      </a>
      {
        !isCourse && (
          <a
            href="/#cursos"
            class="text-sm font-medium transition-opacity hover:opacity-60"
            style="color: var(--text-muted);"
          >
            Ver cursos e mentoria →
          </a>
        )
      }
    </footer>
    </article>
  </div>
</BaseLayout>
