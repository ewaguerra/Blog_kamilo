---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import YouTubeSection from '../../components/YouTubeSection.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout wide title="Blog" description="Estudos, traduções, práticas e mentoria em PGM, ocultismo e magia helenística.">
  <section class="py-4">
    <div class="mb-10">
      <span class="pill mb-4">Blog</span>
      <h1 class="mb-3 text-3xl font-bold tracking-tight sm:text-4xl">Estudos e práticas</h1>
      <p class="text-base" style="color: var(--text-muted);">
        Artigos, traduções e análises sobre PGM, teurgia ctônica, hygromanteia e goetia — {posts.length} {posts.length === 1 ? 'publicação' : 'publicações'}
      </p>
    </div>

    {
      posts.length === 0 ? (
        <p style="color: var(--text-muted);">Nenhum artigo ainda. Em breve!</p>
      ) : (
        <div class="grid gap-5 sm:grid-cols-2">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )
    }

    <YouTubeSection />
  </section>
</BaseLayout>
