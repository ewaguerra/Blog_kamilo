---
import BaseLayout from '../../layouts/BaseLayout.astro';
import PostCard from '../../components/PostCard.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());
---

<BaseLayout title="Blog" description="Todos os artigos do blog.">
  <section>
    <h1 class="mb-2 text-3xl font-bold tracking-tight sm:text-4xl">Blog</h1>
    <p class="mb-10 text-base" style="color: var(--text-muted);">
      {posts.length} {posts.length === 1 ? 'artigo publicado' : 'artigos publicados'}
    </p>

    {
      posts.length === 0 ? (
        <p style="color: var(--text-muted);">Nenhum artigo ainda. Em breve!</p>
      ) : (
        <div class="grid gap-6 sm:grid-cols-2">
          {posts.map((post) => (
            <PostCard post={post} />
          ))}
        </div>
      )
    }
  </section>
</BaseLayout>
